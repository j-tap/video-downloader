PORT=3000
APP_NAME=downloadervr9pro
TRAEFIK_DOMAIN=site.com

# Опционально: SOCKS/HTTP прокси для всех сайтов (например socks5://127.0.0.1:9050)
# PROXY=
# Для совместимости можно также оставить YT_PROXY
# YT_PROXY=

# Cookies (Netscape). Для kino.pub обычно нужна активная сессия через cookies.
# Положите файл в data/cookies.txt (или data/cookiesYoutube.txt) — путь подхватится автоматически.
# Явный путь (локально или в Docker):
# COOKIES_FILE=./data/cookies.txt
# COOKIES_FILE=/app/data/cookies.txt
# Для совместимости можно также использовать YT_COOKIES_FILE

# Отдельный файл cookies для kino.pub (приоритетнее, чем COOKIES_FILE)
# KINOPUB_COOKIES_FILE=./data/cookiesKinoPub.txt
# KINOPUB_COOKIES_FILE=/app/data/cookiesKinoPub.txt

# Опционально: взять cookies напрямую из браузера (chrome/firefox/safari)
# COOKIES_FROM_BROWSER=chrome
# Для совместимости можно также использовать YT_COOKIES_FROM_BROWSER
# Отдельно для kino.pub:
# KINOPUB_COOKIES_FROM_BROWSER=chrome


# Опционально: PO Token для YouTube (см. https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide)
# YT_PO_TOKEN=web.gvs+TOKEN,web.player=TOKEN

# Опционально: переопределить player_client (по умолчанию — автовыбор yt-dlp)
# YT_PLAYER_CLIENT=mweb,android_vr,web_safari

# Путь к бинарнику yt-dlp (по умолчанию yt-dlp)
# YTDLP_PATH=yt-dlp
