PORT=3000
APP_NAME=video-downloader
TRAEFIK_DOMAIN=site.com

# Опционально: SOCKS/HTTP прокси для YouTube (например socks5://127.0.0.1:9050)
# YT_PROXY=

# Cookies YouTube (Netscape). На сервере: data/cookiesYoutube.txt → /app/data/cookiesYoutube.txt в контейнере
YT_COOKIES_FILE=/app/data/cookiesYoutube.txt

# Опционально: PO Token для YouTube (см. https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide)
# YT_PO_TOKEN=web.gvs+TOKEN,web.player=TOKEN

# Опционально: переопределить player_client (по умолчанию — автовыбор yt-dlp)
# YT_PLAYER_CLIENT=mweb,android_vr,web_safari

# Путь к бинарнику yt-dlp (по умолчанию yt-dlp)
# YTDLP_PATH=yt-dlp
